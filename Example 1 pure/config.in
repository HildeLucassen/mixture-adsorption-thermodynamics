# ---- Data selection ----
ADSORBENT               Bhathia_01              # space/comma-separated list; e.g. Bhatia_01, Bhatia_02
ADSORBATE               R125                   # space/comma-separated list; e.g. R125, R134a
TEMPERATURE             [283,303,333,353]           # K; leave blank to auto-select from fittings
FIT_TYPE                Sips                    # space/comma-separated list; e.g. Sips, Toth, Langmuir-Freundlich
NUM_ISOTHERM_SITES      2
P_MIN                   100                     # Pa
P_MAX                   3e06                    # Pa
PRESSURE_UNIT           Pa
PRESSURE_SCALE          log                     # or linear or both

# ---- Input data ----
DATA_FILE_FITTING       Input\data_parameters.txt   # isotherm fitting parameters (used when DATA_SOURCE=fitting)
DATA_SOURCE             fitting                                     # 'fitting' or 'points'

# ---- What to compute / plot ----
HEAT_OF_ADSORPTION          both                        # 'virial', 'cc', 'file', or 'both' (file = plot pure HOA from DATA_FILE_HOA)
STORAGE_DENSITY             both                        # 'virial', 'cc', 'both', 'file', or 'no' ('file' = use Qst from DATA_FILE_HOA with same SD integrals)
STORAGE_DENSITY_DIMENSION   both                        # '3D' or 'both'

# ---- Virial polynomial degrees ----
SUGGESTION_VIRIAL       no                             # yes = auto-search and apply best (deg_a, deg_b) per combo
VIRIAL_DEGREES          (4, 3)

# ---- Storage density parameters ----
P_DES_MIN               1e03                 # Pa, minimum desorption pressure
P_DES_MAX               1e05                 # Pa, maximum desorption pressure
T_ADS                   283                  # K,  fixed adsorption temperature
P_ADS                   1e05                 # Pa, fixed adsorption pressure
T_DES                   [283, 303, 333, 353]      # K,  desorption temperatures (default: seleted temperatures)
P_ADS_TT                1e06                 # Pa, adsorption pressure  (T_ads–T_des 3D plot)
P_DES_TT                1e03                 # Pa, desorption pressure  (T_ads–T_des 3D plot)

# ---- Calculation ----
N_LOADINGS              50

# ---- Output ----
SHOW_PLOTS              no
OUT_DIR                 yes

