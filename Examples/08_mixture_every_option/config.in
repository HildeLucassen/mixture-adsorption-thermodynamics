# ---- Data selection ----
ADSORBENT               Bhathia_01   # space/comma-separated list; e.g. Bhatia_01, Bhatia_02
ADSORBATE               R407F                # space/comma-separated list; e.g. R125, R134a
TEMPERATURE             [283,303,333,353]               # K; leave blank to auto-select from fittings
FIT_TYPE                Sips                    # space/comma-separated list; e.g. Sips, Toth, Langmuir-Freundlich
NUM_ISOTHERM_SITES      2
P_MIN                   100                     # Pa
P_MAX                   3e06                    # Pa
PRESSURE_UNIT           Pa
PRESSURE_SCALE          log                     # or linear or both

# ---- Input data ----
DATA_FILE_FITTING       Input\data_parameters.txt            # RASPA simulation results    (used when DATA_SOURCE=points)
DATA_FILE_POINTS        Input\data_points.txt            # RASPA simulation results    (used when DATA_SOURCE=points)
DATA_FILE_HOA           Input\data_heat_of_adsorption.txt
DATA_SOURCE             fitting

# ---- What to compute / plot ----
HEAT_OF_ADSORPTION_MIX      cc, both                   # 'cc', 'hoa_pure_cc', 'hoa_pure_virial', 'hoa_file', 'both'
STORAGE_DENSITY             cc, both 
STORAGE_DENSITY_DIMENSION   per_component, both                        # 2d | 3d | both | per_component (only possible for HEAT_OF_ADSORPTION_MIX = cc)

# ---- Storage density parameters ----
P_DES_MIN               1e03                    # Pa, minimum desorption pressure
P_DES_MAX               1e05                    # Pa, maximum desorption pressure
T_ADS                   283                     # K,  fixed adsorption temperature
P_ADS                   5e04                    # Pa, fixed adsorption pressure
T_DES                   [283, 303, 333, 353]    # K,  desorption temperatures (default: seleted temperatures)
P_ADS_TT                1e06                    # Pa, adsorption pressure  (T_ads–T_des 3D plot)
P_DES_TT                1e03                    # Pa, desorption pressure  (T_ads–T_des 3D plot)

# ---- Output ----
SHOW_PLOTS              no
OUT_DIR                 yes
