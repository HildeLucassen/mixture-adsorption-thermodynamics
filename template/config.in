# ---- Data selection ----
ADSORBENT               xx                      # space/comma-separated list; e.g. Bhatia_01, Bhatia_02
ADSORBATE               xx                      # space/comma-separated list; e.g. R125, R134a
TEMPERATURE             [xx,xx,xx,xx]           # K; leave blank to auto-select from fittings, minimum 3 Temperatures
FIT_TYPE                xx                      # space/comma-separated list; e.g. Sips, Toth, Langmuir-Freundlich
NUM_ISOTHERM_SITES      xx                      # example dual-sided Sips = 2
P_MIN                   xx                      # same unit as PRESSURE_UNIT
P_MAX                   xx                      # same unit as PRESSURE_UNIT 
PRESSURE_UNIT           xx                      # Pa or kPa
PRESSURE_SCALE          xx                      # log,linear or both

# ---- Input data ----
DATA_FILE_FITTING       Input\xxxxxx.txt           # isotherm fitting parameters (used when DATA_SOURCE=fitting)
DATA_FILE_POINTS        Input\xxxxxx.txt           # RASPA simulation results    (used when DATA_SOURCE=points)
DATA_FILE_HOA           Input\xxxxxx.txt           # HOA: If input is a HOA file
DATA_SOURCE             fitting                    # 'fitting' or 'points'

# ---- What to compute / plot ----
HEAT_OF_ADSORPTION          xx              # 'virial', 'cc', 'file', or 'both' (cc + virial)
HEAT_OF_ADSORPTION_MIX      xx              # 'cc', 'hoa_pure_cc', 'hoa_pure_virial', 'hoa_file', 'both' ('hoa_pure_cc' or 'hoa_pure_cc')
STORAGE_DENSITY             xx              # 'virial', 'cc', 'both', 'file', or 'no' ('file' = use Qst from DATA_FILE_HOA with same SD integrals)
STORAGE_DENSITY_DIMENSION   xx              # e.g. 2d, 3d, both, per_component (only possible for HEAT_OF_ADSORPTION_MIX = cc)

# ---- Virial polynomial degrees ----
SUGGESTION_VIRIAL       yes/no                              # yes = auto-search and apply best (deg_a, deg_b) per combo
VIRIAL_DEGREES          (x, x)                              # Ignored when SUGGESTION_VIRIAL = yes
# VIRIAL_DEGREES_COMBO  adsorbent  adsorbate  x  x          # one line per (structure, molecule); overrides VIRIAL_DEGREES for that pair when SUGGESTION_VIRIAL = no

# ---- Storage density parameters ----
P_DES_MIN               xx                 # minimum desorption pressure (same unit as PRESSURE_UNIT)
P_DES_MAX               xx                 # maximum desorption pressure (same unit as PRESSURE_UNIT)
T_ADS                   xx                 # K,  fixed adsorption temperature
P_ADS                   xx                 # fixed adsorption pressure (same unit as PRESSURE_UNIT)
T_DES                   [xx,xx,xx,xx]      # K,  desorption temperatures (default: seleted temperatures)
P_ADS_TT                xx                 # adsorption pressure, T_ads–T_des 3D plot (same unit as PRESSURE_UNIT)
P_DES_TT                xx                 # desorption pressure, T_ads–T_des 3D plot (same unit as PRESSURE_UNIT)

# ---- Calculation ----
N_LOADINGS              xx                 # Amount of points used for heat of adsorption

# ---- Output ----
SHOW_POINTS             yes/no
SHOW_PLOTS              yes/no
OUT_DIR                 yes/no

# Legend label for DATA_FILE_HOA curve only (CC and Virial are fixed). Default: Data
HOA_LEGEND_FILE         xx
